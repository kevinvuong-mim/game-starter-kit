# Environment - dev | staging | production
VITE_APP_ENV="dev"

# Game config - must match backend config
VITE_GAME_ID="FRULOOP"
VITE_REPLAY_SECRET="abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234abcd1234"

# IAP provider: mock | revenuecat
VITE_IAP_PROVIDER="mock"
# RevenueCat API keys - required when VITE_IAP_PROVIDER=revenuecat
# VITE_REVENUECAT_IOS_API_KEY=
# VITE_REVENUECAT_ANDROID_API_KEY=

# Ads provider: mock | admob
VITE_ADS_PROVIDER="mock"
# iOS - required when VITE_ADS_PROVIDER=admob
# VITE_ADMOB_IOS_APP_ID=
# VITE_ADMOB_IOS_BANNER_ID=
# VITE_ADMOB_IOS_APP_OPEN_ID=
# VITE_ADMOB_IOS_REWARDED_ID=
# VITE_ADMOB_IOS_INTERSTITIAL_ID=
# Android - required when VITE_ADS_PROVIDER=admob
# VITE_ADMOB_ANDROID_APP_ID=
# VITE_ADMOB_ANDROID_BANNER_ID=
# VITE_ADMOB_ANDROID_APP_OPEN_ID=
# VITE_ADMOB_ANDROID_REWARDED_ID=
# VITE_ADMOB_ANDROID_INTERSTITIAL_ID=

# Analytics provider: console | firebase
VITE_ANALYTICS_PROVIDER="console"
# Firebase - required when VITE_ANALYTICS_PROVIDER=firebase
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_MEASUREMENT_ID=
