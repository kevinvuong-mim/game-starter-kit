# ─────────────────────────────────────────────
# Core — dùng hằng ngày khi dev
# ─────────────────────────────────────────────
VITE_APP_ENV=dev
# Optional override for all environments. Defaults are derived from VITE_APP_ENV.
# Production/staging values must use HTTPS.
VITE_API_URL=http://localhost:3000/api
VITE_IAP_ENABLED=false
# IAP provider: mock | revenuecat (revenuecat only works on native builds)
VITE_IAP_PROVIDER=mock

# RevenueCat public API keys — chỉ cần khi build native với VITE_IAP_PROVIDER=revenuecat
VITE_REVENUECAT_ANDROID_API_KEY=
VITE_REVENUECAT_IOS_API_KEY=

# Ads provider: mock | admob
VITE_ADS_PROVIDER=mock
# true → dùng Google test ad units (bỏ qua mọi ad unit ID bên dưới)
VITE_ADMOB_TESTING=true

# ─────────────────────────────────────────────
# AdMob App ID — chỉ cần khi build native thật
# Mỗi platform là 1 app riêng trong AdMob.
# ─────────────────────────────────────────────
VITE_ADMOB_ANDROID_APP_ID=
VITE_ADMOB_IOS_APP_ID=

# ─────────────────────────────────────────────
# AdMob Ad Unit IDs — CHỈ cần khi release production
# (khi VITE_ADMOB_TESTING=false). Lúc dev có thể bỏ trống.
# Bỏ comment khi đã có ad unit thật.
# ─────────────────────────────────────────────
# Android
# VITE_ADMOB_ANDROID_BANNER_ID=
# VITE_ADMOB_ANDROID_INTERSTITIAL_ID=
# VITE_ADMOB_ANDROID_REWARDED_ID=
# VITE_ADMOB_ANDROID_APP_OPEN_ID=
# iOS
# VITE_ADMOB_IOS_BANNER_ID=
# VITE_ADMOB_IOS_INTERSTITIAL_ID=
# VITE_ADMOB_IOS_REWARDED_ID=
# VITE_ADMOB_IOS_APP_OPEN_ID=

# ─────────────────────────────────────────────
# Firebase Analytics — Chỉ cần cho staging/production
# (dev có analyticsEnabled=false nên không dùng).
# Bỏ comment khi deploy staging/prod.
# ─────────────────────────────────────────────
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_MEASUREMENT_ID=
